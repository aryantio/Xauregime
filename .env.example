# Copy to .env and fill in before running docker compose up

# --- FRED (required for live data) ---
FRED_API_KEY=your_fred_key_here         # https://fredaccount.stlouisfed.org/apikey

# --- Anthropic (required for FOMC scoring experiment) ---
ANTHROPIC_API_KEY=your_anthropic_key    # https://console.anthropic.com/

# --- Postgres (defaults work fine for local dev) ---
POSTGRES_USER=regime
POSTGRES_PASSWORD=regime
POSTGRES_DB=regimedb
